# ── Panmira Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── AI Provider (required) ──
# Anthropic-compatible API token (supports Anthropic, OpenAI-compatible providers)
ANTHROPIC_AUTH_TOKEN=your-api-key-here
# Base URL for AI provider (change for non-Anthropic providers)
# Anthropic: https://api.anthropic.com
# OpenAI-compatible: https://api.openai.com/v1
# 智谱: https://open.bigmodel.cn/api/anthropic
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Claude Code ──
# Default working directory for bot workspaces (created automatically)
CLAUDE_DEFAULT_WORKING_DIRECTORY=./workspace
# Disable auto-memory (0=enabled, 1=disabled)
CLAUDE_CODE_DISABLE_AUTO_MEMORY=0

# ── HTTP API ──
API_PORT=9100
# Secret token for API authentication (change this!)
API_SECRET=change-me-to-a-secure-secret

# ── Database (required) ──
# PostgreSQL connection string (with pgvector extension)
DATABASE_URL=postgresql://metabot:metabot@localhost:5432/metabot
# JWT secret for session tokens (change this!)
JWT_SECRET=change-me-to-a-random-string

# ── MetaMemory (optional) ──
# Enable/disable memory service integration
MEMORY_ENABLED=false
# MetaMemory service URL (only if MEMORY_ENABLED=true)
META_MEMORY_URL=http://localhost:8100
# Admin token for MetaMemory service
MEMORY_ADMIN_TOKEN=memory_admin_token

# ── Security ──
# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# ── Logging ──
LOG_LEVEL=info

# ── Node.js ──
NODE_OPTIONS=--no-deprecation
