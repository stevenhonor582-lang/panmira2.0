{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://metabot.local/schemas/write-proposal.v1.json",
  "title": "WriteProposalIO",
  "input": {
    "type": "object",
    "required": ["topic", "topic_category", "audience", "length"],
    "properties": {
      "topic": {
        "type": "string",
        "minLength": 2,
        "maxLength": 100,
        "description": "方案主题"
      },
      "topic_category": {
        "type": "string",
        "enum": ["产品介绍", "技术方案", "商业计划", "营销方案", "内部提案"],
        "default": "技术方案",
        "description": "方案类型（用于模板选择）"
      },
      "audience": {
        "type": "string",
        "enum": ["管理层", "技术团队", "客户", "投资人", "合作伙伴"],
        "description": "目标读者"
      },
      "length": {
        "type": "string",
        "enum": ["500字", "1500字", "3000字", "5000字+"],
        "description": "期望篇幅"
      },
      "key_points": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 1,
        "maxItems": 10,
        "description": "核心要点（用户提供的素材）"
      },
      "tone": {
        "type": "string",
        "enum": ["正式", "务实", "前瞻", "保守"],
        "default": "务实",
        "description": "方案语气"
      },
      "deadline": {
        "type": "string",
        "format": "date-time",
        "description": "交付截止时间（可选）"
      }
    }
  },
  "output": {
    "type": "object",
    "required": ["title", "outline", "body", "word_count", "quality_report", "metadata"],
    "properties": {
      "title": {
        "type": "string",
        "description": "方案标题"
      },
      "outline": {
        "type": "array",
        "items": { "type": "string" },
        "description": "目录结构"
      },
      "body": {
        "type": "string",
        "description": "方案正文（Markdown 格式）"
      },
      "word_count": {
        "type": "integer",
        "description": "正文字数"
      },
      "feishu_doc_url": {
        "type": "string",
        "description": "飞书文档 URL（mock 模式时为 mock URL）"
      },
      "quality_report": {
        "type": "object",
        "required": ["passed", "score", "issues"],
        "properties": {
          "passed": {
            "type": "boolean",
            "description": "是否通过质量自检"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "质量评分（0-100）"
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["forbidden_word", "word_count", "missing_section", "heading_level", "key_point_uncovered"] },
                "severity": { "type": "string", "enum": ["error", "warning", "info"] },
                "message": { "type": "string" }
              }
            },
            "description": "问题列表"
          }
        }
      },
      "metadata": {
        "type": "object",
        "required": ["template_used", "generated_at", "iterations", "readability_score", "target_audience_styled"],
        "properties": {
          "template_used": { "type": "string", "description": "使用的模板文件名" },
          "generated_at": { "type": "string", "format": "date-time" },
          "iterations": { "type": "integer", "description": "修正循环轮数" },
          "readability_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "target_audience_styled": { "type": "boolean", "description": "是否已按受众调整语气" }
        }
      }
    }
  }
}
