# apps/web-next environment variables (committed example — copy to .env.web-next)
#
# PANMIRA_BACKEND_URL — the upstream base URL that next.config.ts rewrites
# forward /api/* to. Defaults to http://localhost:9100 if unset, which keeps
# local dev working out of the box. In production set this to the real
# backend origin (e.g. https://api.deepx.fun).
PANMIRA_BACKEND_URL=http://localhost:9100
# tldraw 画布 license key(内部工具可免费申请:https://tldraw.com/#pricing)
# 不设也能用,仅 console 会有 license 提示(水印已 CSS 隐藏)
NEXT_PUBLIC_TLDRAW_LICENSE_KEY=
